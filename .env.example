# =============================================================================
# Ceduverse Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- REQUIRED (server will not start without these) ---

# PostgreSQL connection string
DB_URL=postgresql://user:password@localhost:5432/ceduverse

# Secret for JWT signing — use a long random string (min 32 chars)
SESSION_SECRET=change-me-to-a-random-secret-string

# --- SECURITY ---

# Separate API key for admin migration/import endpoints
# Falls back to SESSION_SECRET if not set — strongly recommended to set separately
ADMIN_API_KEY=

# Kakaw HQ connector: shared secret the HQ sends as x-hq-secret to GET /api/hq/metrics.
# If unset, that endpoint is disabled (503). Set the same value in the HQ.
HQ_METRICS_SECRET=

# Initial superadmin password (used only during first seed)
SUPERADMIN_PASSWORD=

# --- DEMO ACCOUNTS (optional, JSON array) ---
# When set, these emails auto-login without OTP. Remove in production.
# DEMO_ACCOUNTS='[{"email":"demo@ceduverse.org","fullName":"Demo User","role":"socio_estudiante"}]'

# --- EMAIL ---

# Resend API key for sending OTP codes, kit PDFs, SAM confirmations
RESEND_API_KEY=

# --- AI SERVICES ---

# OpenAI API key for AI tutoring and content generation
OPENAI_API_KEY=

# Anthropic API key for Claude AI features
ANTHROPIC_API_KEY=

# --- VIDEO & AVATAR ---

# HeyGen API key for AI avatar video generation
HEYGEN_API_KEY=

# Daily.co API key for video conferencing / live tutoring
DAILY_API_KEY=

# --- PAYMENTS ---

# Stripe secret key (server-side; sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...) — required to verify webhook events
STRIPE_WEBHOOK_SECRET=

# --- INVOICING ---

# FacturAPI key for CFDI Mexican electronic invoicing
FACTURAPI_API_KEY=

# --- SHIPPING ---

# Envia.com API key for shipment label generation
ENVIA_API_KEY=

# --- BANK INFO (for SAM contribution payment instructions) ---

BANK_NAME=BanRegio
BANK_CLABE=058580000000000000
BANK_BENEFICIARY=Ceduverse S.C.

# --- ACADEMY SYNC ---

# Secret for WordPress/Academy API sync
ACADEMY_SECRET=
ACADEMY_SITE_URL=

# --- GENERAL ---

# Base URL for the application (used in email links)
BASE_URL=https://ceduverse.org

# Server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=development

# --- Google Calendar / Meet (CRM meeting scheduling) ---
# Free Gmail + OAuth (no Workspace needed). See scripts/google-oauth-setup.mjs.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Optional: which calendar to create events on (default "primary")
GOOGLE_MEET_CALENDAR_ID=primary
# Optional: timezone for events (default America/Mexico_City)
GOOGLE_MEET_TIMEZONE=America/Mexico_City
